{
    "$schema": "https://cdn.jsdelivr.net/gh/memizy/oqse-specification@main/schemas/oqse-manifest-v0.1.json",
    "version": "0.1",
    "pluginVersion": "1.0.0",
    "minOqseVersion": "0.1",
    "maxOqseVersion": "1.99",
    "id": "https://memizy.github.io/multiplayer-quiz/",
    "appName": "Multiplayer Quiz",
    "description": "Real-time multiplayer quiz game with live leaderboard, configurable time limits, and competitive gameplay for classrooms and study groups.",
    "author": {
      "name": "Memizy Dev Team",
      "role": "Creator"
    },
    "locales": ["en", "cs"],
    "tags": ["quiz", "multiplayer", "game", "real-time", "leaderboard"],
    "emoji": "🎮",
    "studyMode": "game",
    "questionDensity": "high",
    "capabilities": {
      "actions": ["render"],
      "types": ["mcq-single", "mcq-multi", "true-false", "short-answer", "match-pairs"],
      "assets": {
        "image": ["image/jpeg", "image/png", "image/svg+xml", "image/webp"],
        "audio": null,
        "video": null,
        "model": null
      },
      "features": ["markdown"]
    },
    "appSpecific": {
      "memizy": {
        "multiplayer": {
          "apiVersion": "0.3",
          "players": {
            "min": 2,
            "max": 60,
            "recommended": 30
          },
          "supportsLateJoin": true,
          "supportsReconnect": true,
          "supportsTeams": false,
          "requiresHostScreen": true,
          "clientOrientation": "portrait"
        }
      }
    }
  }